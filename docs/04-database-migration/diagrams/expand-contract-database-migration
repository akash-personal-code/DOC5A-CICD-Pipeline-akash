digraph "Zero-Downtime Database Migration: Expand-Contract" {
	bgcolor=white nodesep=0.55 pad=0.35 rankdir=LR ranksep=0.75 splines=ortho
	graph [fontname=Arial fontsize=16 label="Zero-Downtime Database Migration: Expand-Contract" labelloc=t]
	node [color="#2D3748" fillcolor="#F7FAFC" fontname=Arial fontsize=10 margin="0.09,0.07" penwidth=1.6 shape=rect style="rounded,filled"]
	edge [arrowsize=0.7 color="#2D3748" fontname=Arial fontsize=9 penwidth=1.4]
	baseline [label="Baseline schema
App V(N-1) online" fillcolor="#E6F2FF"]
	expand [label="EXPAND
Add nullable columns/tables/indexes
backward compatible" fillcolor="#EAF7EA"]
	deploy [label="Deploy App V(N)
Dual-read/write compatible" fillcolor="#F7FAFC"]
	backfill [label="MIGRATE
Idempotent throttled backfill
100M+ rows, abort >20% latency impact" fillcolor="#FFF4E5"]
	validate [label="Validate
counts, checksums, synthetic transactions" fillcolor="#EAF7EA"]
	contract [label="CONTRACT
Remove old columns only after approval
forward-only change" fillcolor="#FDEAEA"]
	stable [label="Final schema
App V(N) only + evidence" fillcolor="#EAF7EA"]
	rollback [label="Rollback/abort paths
Expand reversible, migrate retryable, contract gated" fillcolor="#FDEAEA"]
	baseline -> expand
	expand -> deploy
	deploy -> backfill
	backfill -> validate
	validate -> contract [label="after bake + DBA approval"]
	contract -> stable
	expand -> rollback [label=failure]
	backfill -> rollback [label="latency/CV failure"]
	validate -> rollback [label="data mismatch"]
}
