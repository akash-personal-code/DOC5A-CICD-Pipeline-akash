{
  "title": "NovaPay Lite Dashboard",
  "panels": [
    {
      "title": "HTTP Request Count",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Payment Processing Success/Failure",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(payment_count_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "p95 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))"
        }
      ]
    }
  ],
  "schemaVersion": 30
}
